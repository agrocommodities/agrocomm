doctype html
html(lang="pt-BR")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Pagamento via Pix — AgroComm
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background-color: #1a1a1a;
        color: #e0e0e0;
        -webkit-font-smoothing: antialiased;
      }
      .wrapper {
        max-width: 560px;
        margin: 0 auto;
        padding: 40px 20px;
      }
      .card {
        background-color: #2a3925;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
      }
      .header {
        background: linear-gradient(135deg, #394634 0%, #2d3a28 100%);
        padding: 32px 32px 28px;
        text-align: center;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      .logo-container {
        display: inline-block;
        margin-bottom: 8px;
      }
      .logo-container img {
        width: 52px;
        height: 52px;
      }
      .brand-name {
        font-size: 22px;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.3px;
      }
      .body {
        padding: 32px;
      }
      .greeting {
        font-size: 18px;
        font-weight: 600;
        color: #ffffff;
        margin-bottom: 16px;
      }
      .text {
        font-size: 14px;
        line-height: 1.7;
        color: rgba(255,255,255,0.7);
        margin-bottom: 12px;
      }
      .amount-highlight {
        font-size: 28px;
        font-weight: 700;
        color: #4ade80;
        text-align: center;
        margin: 20px 0;
      }
      .qr-wrapper {
        text-align: center;
        margin: 24px 0;
      }
      .qr-wrapper img {
        width: 200px;
        height: 200px;
        border-radius: 12px;
        border: 2px solid rgba(255,255,255,0.1);
      }
      .pix-code-box {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 10px;
        padding: 16px;
        margin: 24px 0;
      }
      .pix-code-label {
        font-size: 12px;
        font-weight: 600;
        color: rgba(255,255,255,0.5);
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .pix-code-value {
        font-size: 12px;
        font-family: 'Courier New', monospace;
        color: rgba(255,255,255,0.8);
        word-break: break-all;
        line-height: 1.6;
      }
      .warning {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 10px;
        padding: 16px;
        margin-top: 24px;
      }
      .warning-title {
        font-size: 13px;
        font-weight: 600;
        color: rgba(255,255,255,0.6);
        margin-bottom: 6px;
      }
      .warning-text {
        font-size: 12px;
        line-height: 1.6;
        color: rgba(255,255,255,0.4);
      }
      .divider {
        border: none;
        border-top: 1px solid rgba(255,255,255,0.06);
        margin: 0;
      }
      .footer {
        padding: 24px 32px;
        text-align: center;
      }
      .footer-text {
        font-size: 12px;
        color: rgba(255,255,255,0.3);
        line-height: 1.6;
      }
      .footer-text a {
        color: #4ade80;
        text-decoration: none;
      }
  body
    .wrapper
      .card
        .header
          .logo-container
            img(src=logoUrl alt="AgroComm")
          div.brand-name AgroComm
        .body
          p.greeting Olá, #{userName}!
          p.text Seu pagamento via Pix foi gerado. Escaneie o QR Code abaixo ou copie o código Pix para realizar o pagamento.
          p.amount-highlight R$ #{amount}
          .qr-wrapper
            img(src="data:image/png;base64," + qrCodeBase64 alt="QR Code Pix")
          .pix-code-box
            p.pix-code-label Código Pix (copia e cola)
            p.pix-code-value= pixCode
          .warning
            p.warning-title Como pagar
            p.warning-text Abra o aplicativo do seu banco, acesse a área Pix e escolha "Pagar com QR Code" ou "Pix Copia e Cola". O pagamento é processado instantaneamente.
        hr.divider
        .footer
          p.footer-text © #{new Date().getFullYear()} AgroComm — Cotações agropecuárias em tempo real.
            br
            | Este é um e-mail automático, não responda.
