doctype html
html(lang="pt-BR")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Boletim de cotações — AgroComm
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background-color: #1a1a1a;
        color: #e0e0e0;
        -webkit-font-smoothing: antialiased;
      }
      .wrapper {
        max-width: 560px;
        margin: 0 auto;
        padding: 40px 20px;
      }
      .card {
        background-color: #2a3925;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
      }
      .header {
        background: linear-gradient(135deg, #394634 0%, #2d3a28 100%);
        padding: 32px 32px 28px;
        text-align: center;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      .logo-container {
        display: inline-block;
        margin-bottom: 8px;
      }
      .logo-container img {
        width: 52px;
        height: 52px;
      }
      .brand-name {
        font-size: 22px;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.3px;
      }
      .body {
        padding: 32px;
      }
      .greeting {
        font-size: 18px;
        font-weight: 600;
        color: #ffffff;
        margin-bottom: 16px;
      }
      .text {
        font-size: 14px;
        line-height: 1.7;
        color: rgba(255,255,255,0.7);
        margin-bottom: 12px;
      }
      .quote-table {
        width: 100%;
        border-collapse: collapse;
        margin: 24px 0;
      }
      .quote-table th {
        font-size: 11px;
        font-weight: 600;
        color: rgba(255,255,255,0.5);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 10px 8px;
        text-align: left;
        border-bottom: 1px solid rgba(255,255,255,0.1);
      }
      .quote-table td {
        font-size: 13px;
        color: rgba(255,255,255,0.8);
        padding: 10px 8px;
        border-bottom: 1px solid rgba(255,255,255,0.04);
      }
      .quote-table .product-name {
        font-weight: 600;
        color: #ffffff;
      }
      .quote-table .location {
        font-size: 11px;
        color: rgba(255,255,255,0.4);
      }
      .quote-table .price {
        font-weight: 600;
        color: #4ade80;
        text-align: right;
      }
      .quote-table .variation {
        text-align: right;
        font-size: 12px;
        font-weight: 600;
      }
      .variation-up {
        color: #4ade80;
      }
      .variation-down {
        color: #ef4444;
      }
      .variation-neutral {
        color: rgba(255,255,255,0.4);
      }
      .btn-wrapper {
        text-align: center;
        margin: 28px 0 0;
      }
      .btn-secondary {
        display: inline-block;
        color: #4ade80 !important;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        padding: 10px 24px;
        border-radius: 10px;
        border: 1px solid rgba(74,222,128,0.3);
      }
      .divider {
        border: none;
        border-top: 1px solid rgba(255,255,255,0.06);
        margin: 0;
      }
      .footer {
        padding: 24px 32px;
        text-align: center;
      }
      .footer-text {
        font-size: 12px;
        color: rgba(255,255,255,0.3);
        line-height: 1.6;
      }
      .footer-text a {
        color: #4ade80;
        text-decoration: none;
      }
  body
    .wrapper
      .card
        .header
          .logo-container
            img(src=logoUrl alt="AgroComm")
          div.brand-name AgroComm
        .body
          p.greeting Olá, #{userName}!
          p.text Confira as cotações que você acompanha:
          table.quote-table
            thead
              tr
                th Produto
                th.price Preço
                th.variation Var.
            tbody
              each quote in quotes
                tr
                  td
                    span.product-name #{quote.productName}
                    br
                    span.location #{quote.cityName} — #{quote.stateName}
                  td.price R$ #{quote.price}
                  if quote.variation > 0
                    td.variation.variation-up +#{quote.variation}%
                  else if quote.variation < 0
                    td.variation.variation-down #{quote.variation}%
                  else
                    td.variation.variation-neutral 0%
          .btn-wrapper
            a.btn-secondary(href=settingsUrl target="_blank") Gerenciar cotações
        hr.divider
        .footer
          p.footer-text © #{new Date().getFullYear()} AgroComm — Cotações agropecuárias em tempo real.
            br
            | Este é um e-mail automático.
            |
            a(href=settingsUrl) Cancelar boletim
