doctype html
html(lang="pt-BR")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Boletim de notícias — AgroComm
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background-color: #1a1a1a;
        color: #e0e0e0;
        -webkit-font-smoothing: antialiased;
      }
      .wrapper {
        max-width: 560px;
        margin: 0 auto;
        padding: 40px 20px;
      }
      .card {
        background-color: #2a3925;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
      }
      .header {
        background: linear-gradient(135deg, #394634 0%, #2d3a28 100%);
        padding: 32px 32px 28px;
        text-align: center;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      .logo-container {
        display: inline-block;
        margin-bottom: 8px;
      }
      .logo-container img {
        width: 52px;
        height: 52px;
      }
      .brand-name {
        font-size: 22px;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.3px;
      }
      .body {
        padding: 32px;
      }
      .greeting {
        font-size: 18px;
        font-weight: 600;
        color: #ffffff;
        margin-bottom: 16px;
      }
      .text {
        font-size: 14px;
        line-height: 1.7;
        color: rgba(255,255,255,0.7);
        margin-bottom: 12px;
      }
      .article-list {
        margin: 24px 0;
      }
      .article-item {
        display: flex;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      .article-item:last-child {
        border-bottom: none;
      }
      .article-image {
        width: 80px;
        height: 80px;
        border-radius: 8px;
        object-fit: cover;
        flex-shrink: 0;
      }
      .article-content {
        flex: 1;
        min-width: 0;
      }
      .article-title {
        font-size: 14px;
        font-weight: 600;
        color: #ffffff;
        margin-bottom: 6px;
        line-height: 1.4;
      }
      .article-title a {
        color: #ffffff;
        text-decoration: none;
      }
      .article-excerpt {
        font-size: 12px;
        line-height: 1.5;
        color: rgba(255,255,255,0.5);
      }
      .article-link {
        display: inline-block;
        font-size: 12px;
        color: #4ade80;
        text-decoration: none;
        font-weight: 600;
        margin-top: 6px;
      }
      .divider {
        border: none;
        border-top: 1px solid rgba(255,255,255,0.06);
        margin: 0;
      }
      .footer {
        padding: 24px 32px;
        text-align: center;
      }
      .footer-text {
        font-size: 12px;
        color: rgba(255,255,255,0.3);
        line-height: 1.6;
      }
      .footer-text a {
        color: #4ade80;
        text-decoration: none;
      }
  body
    .wrapper
      .card
        .header
          .logo-container
            img(src=logoUrl alt="AgroComm")
          div.brand-name AgroComm
        .body
          p.greeting Olá, #{userName}!
          p.text Confira as últimas notícias do agronegócio:
          .article-list
            each article in articles
              .article-item
                if article.imageUrl
                  img.article-image(src=article.imageUrl alt=article.title)
                .article-content
                  p.article-title
                    a(href=article.url target="_blank")= article.title
                  p.article-excerpt= article.excerpt
                  a.article-link(href=article.url target="_blank") Ler mais →
        hr.divider
        .footer
          p.footer-text © #{new Date().getFullYear()} AgroComm — Cotações agropecuárias em tempo real.
            br
            | Este é um e-mail automático, não responda.
