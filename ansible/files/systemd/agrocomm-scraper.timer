[Unit]
Description=AgroComm Scraper Timer - 6x ao dia, sem sábado/domingo/feriados
Requires=agrocomm-scraper.service

[Timer]
# 06:00, 08:30, 11:00, 13:30, 16:00, 18:00
OnCalendar=Mon-Fri *-*-* 06:00:00
OnCalendar=Mon-Fri *-*-* 08:30:00
OnCalendar=Mon-Fri *-*-* 11:00:00
OnCalendar=Mon-Fri *-*-* 13:30:00
OnCalendar=Mon-Fri *-*-* 16:00:00
OnCalendar=Mon-Fri *-*-* 18:00:00
Persistent=false

[Install]
WantedBy=timers.target
