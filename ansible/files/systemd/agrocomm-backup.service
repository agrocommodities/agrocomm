[Unit]
Description=AgroComm - Backup do banco de dados SQLite
After=network.target

[Service]
Type=oneshot
User=nginx
WorkingDirectory=/var/www/agrocomm
ExecStart=/bin/bash -c 'mkdir -p /var/backups/agrocomm && cp drizzle/agrocomm.db /var/backups/agrocomm/agrocomm-$(date +%%Y%%m%%d-%%H%%M%%S).db && find /var/backups/agrocomm -name "agrocomm-*.db" -mtime +7 -delete'
NoNewPrivileges=true
ProtectSystem=full
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agrocomm-backup
