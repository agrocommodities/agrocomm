[Unit]
Description=AgroComm Bulletins - Boletins e alertas de assinatura
After=network.target

[Service]
Type=oneshot
User=nginx
WorkingDirectory=/var/www/agrocomm
ExecStart=/home/nginx/.local/share/pnpm/pnpm tsx src/db/bulletins.ts
EnvironmentFile=-/var/www/agrocomm/.env
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agrocomm-bulletins
