{
  "name": "agrocomm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=3000 tsx src/server.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx src/server.ts",
    "push": "drizzle-kit push",
    "seed": "tsx src/db/seed.ts",
    "reset": "rm -f drizzle/agrocomm.db && pnpm run push && pnpm run seed && pnpm run scrape",
    "scrape": "tsx src/db/scrape.ts",
    "check": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@next/third-parties": "^16.1.6",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "domhandler": "^5.0.3",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
