{
  "name": "agrocomm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx src/server.ts",
    "push": "drizzle-kit push",
    "seed": "tsx src/db/seed.ts",
    "backup": "mkdir -p drizzle/backups && cp drizzle/agrocomm.db drizzle/backups/agrocomm-$(date +%Y%m%d-%H%M%S).db && echo 'Backup criado em drizzle/backups/'",
    "reset": "pnpm run backup 2>/dev/null; rm -f drizzle/agrocomm.db && pnpm run push && pnpm run seed && pnpm run scrape",
    "scrape": "tsx src/db/scrape.ts",
    "convert-images": "tsx src/db/convert-post-images.ts",
    "check": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@next/third-parties": "^16.2.6",
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "email-templates": "^13.0.1",
    "jose": "^6.2.3",
    "lucide-react": "^0.577.0",
    "mercadopago": "^3.0.0",
    "next": "16.2.6",
    "next-turnstile": "^1.0.7",
    "nodemailer": "^8.0.10",
    "pug": "^3.0.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ua-parser-js": "^2.0.10",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^6.0.4",
    "@types/email-templates": "^10.0.4",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^8.0.0",
    "@types/pug": "^2.0.10",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ua-parser-js": "^0.7.39",
    "domhandler": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
