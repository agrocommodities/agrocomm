# docker/.env — variáveis injetadas no docker-compose via --env-file
# Copie para docker/.env e preencha os valores antes de rodar `make setup`

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=AgroComm
NEXT_PUBLIC_APP_DESC=Commodities agropecuárias
NEXT_PUBLIC_APP_URL=https://agrocomm.local
NEXT_PUBLIC_BASE_URL=https://agrocomm.local

# ── Segurança ─────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=

# Gere com: openssl rand -hex 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ── Banco de dados ────────────────────────────────────────────────────────────
DB_FILE_NAME=file:drizzle/agrocomm.db

# ── Seed do admin (apenas pnpm seed) ─────────────────────────────────────────
ADMIN_EMAIL=admin@agrocomm.local
ADMIN_PASSWORD=

# ── E-mail (Nodemailer) ───────────────────────────────────────────────────────
MAIL_ADDR=
MAIL_USER=
MAIL_PASS=

# ── Formulário de contato (SMTP alternativo) ──────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
CONTACT_EMAIL=

# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────────────────────
# Obtenha em: https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# ── WhatsApp Business API ─────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=

# ── Google Analytics ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
